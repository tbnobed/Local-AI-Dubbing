# DubbingStudio Backend Configuration
# Copy this to .env and update values

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# GPU Configuration
PRIMARY_GPU_ID=0
SECONDARY_GPU_ID=1
USE_GPU=true

# Whisper Model (options: tiny, base, small, medium, large-v2, large-v3)
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# XTTS Voice Cloning
XTTS_DEVICE=cuda

# Translation (options: facebook/nllb-200-distilled-600M, facebook/nllb-200-1.3B, facebook/nllb-200-3.3B)
TRANSLATION_MODEL=facebook/nllb-200-distilled-600M
TRANSLATION_DEVICE=cuda

# Speaker Diarization
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
# Required for pyannote models (get free token at https://huggingface.co/settings/tokens)
HF_TOKEN=your_huggingface_token_here

# Redis
REDIS_URL=redis://localhost:6379/0

# Frontend (relative to backend dir)
FRONTEND_DIR=../frontend/dist
