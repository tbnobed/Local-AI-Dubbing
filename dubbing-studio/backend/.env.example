# DubbingStudio Backend Configuration
# Copy this to .env and update values

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# GPU Configuration (run nvidia-smi to confirm IDs)
PRIMARY_GPU_ID=0
SECONDARY_GPU_ID=1
USE_GPU=true

# WhisperX — Transcription + word alignment + speaker diarization
# Model options: tiny, base, small, medium, large-v2, large-v3, large-v3-turbo
WHISPER_MODEL_SIZE=large-v3-turbo
WHISPER_BATCH_SIZE=16
WHISPER_COMPUTE_TYPE=float16

# Fish Speech — Voice cloning TTS (replaces Coqui XTTS)
FISH_SPEECH_MODEL=fishaudio/fish-speech-1.5
FISH_SPEECH_DEVICE=cuda

# MADLAD-400 — Translation (Apache 2.0, 400+ languages)
# Options: google/madlad400-3b-mt (default), google/madlad400-7b-mt, google/madlad400-10b-mt
TRANSLATION_MODEL=google/madlad400-3b-mt
TRANSLATION_DEVICE=cuda

# Hugging Face token — REQUIRED for speaker diarization (pyannote community-1)
# Get free token at: https://huggingface.co/settings/tokens
# Then accept terms at: https://huggingface.co/pyannote/speaker-diarization-3.1
#                   and: https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=your_huggingface_token_here

# Redis
REDIS_URL=redis://localhost:6379/0

# Frontend (relative to backend dir)
FRONTEND_DIR=../frontend/dist
